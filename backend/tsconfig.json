{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "ignoreDeprecations": "6.0",
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "typeRoots": ["./env.d.ts", "./node_modules/@types"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "../shared/**/*"
  ]
}
